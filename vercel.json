{
    "buildCommand": "npm run build",
    "outputDirectory": "dist/client",
    "framework": "vite",
    "functions": {
        "api/index.js": {
            "includeFiles": "dist/**",
            "memory": 1024
        }
    },
    "rewrites": [
        {
            "source": "/(.*)",
            "destination": "/api/index.js"
        }
    ]
}
